{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "echo \"Add API E2E runner\"",
    "db:migrate": "echo \"Add migration runner\"",
    "openapi:generate": "echo \"Add OpenAPI generation\""
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "^4.0.0",
    "@sinclair/typebox": "^0.32.0",
    "fastify": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "vitest": "^1.6.0"
  }
}
