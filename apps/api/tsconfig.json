{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node",
      "vitest/globals"
    ],
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false
  },
  "include": [
    "src",
    "vitest.setup.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
